{
  "walkthrough": [
    "# The Cartographer's Instrument — Walkthrough",
    "",
    "> look",
    "# Observatory Entrance. See exits: north. The Instrument is on the ground.",
    "",
    "> take instrument",
    "# Pick up The Instrument.",
    "",
    "> north",
    "# Central Hall. See Ghost of the Cartographer. Exits: west, east, up, south.",
    "",
    "> talk",
    "# The Ghost speaks: hints about resonators and notes.",
    "",
    "> west",
    "# West Wing. See Lunar Resonator, Lunar Chart.",
    "",
    "> examine chart",
    "# Clue: the moon's tone is the root, the lowest, the foundation.",
    "",
    "> play resonator",
    "# The Lunar Resonator activates. A deep C drone rises.",
    "",
    "> east",
    "# Back to Central Hall. The lunar layer now plays here too.",
    "",
    "> east",
    "# East Wing. See Solar Resonator, Solar Chart.",
    "",
    "> examine chart",
    "# Clue: the sun's tone is the fifth, bright and ascending.",
    "",
    "> play resonator",
    "# The Solar Resonator activates. A bright G arpeggio rings.",
    "",
    "> west",
    "# Central Hall. Both layers now audible.",
    "",
    "> up",
    "# Tower (requires both resonators active). See Stellar Resonator, Stellar Chart.",
    "",
    "> examine chart",
    "# Clue: the stars' tone is the third, the bridge.",
    "",
    "> play resonator",
    "# The Stellar Resonator activates. The final E note joins. Something opens below.",
    "",
    "> down",
    "# Central Hall. All three layers playing.",
    "",
    "> down",
    "# Star Chamber (now accessible). Full composition plays. Endgame fires.",
    "",
    "# THE END — The Cartographer's Composition is complete."
  ],
