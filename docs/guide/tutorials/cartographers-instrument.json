        ],
        [
          "title",
          "West Wing — Lunar Observatory"
        ],
        [
          "exit",
          "east"
        ],
        [
          "feature",
          "30078:<PUBKEY>:cartographers-instrument:feature:lunar-resonator"
        ],
        [
          "feature",
          "30078:<PUBKEY>:cartographers-instrument:feature:lunar-chart"
        ]
      ],
      "content": "A circular chamber lined with curved mirrors that once tracked the moon's passage. The mirrors are tarnished now, their surfaces clouded with age. Lunar phase diagrams cover the walls — waxing, waning, full, dark — each annotated with faded musical notation.\n\nAt the centre of the room stands a stone column topped with a complex arrangement of concentric rings. It hums faintly, waiting."
    },
    {
      "kind": 30078,
      "tags": [
        [
          "d",
          "cartographers-instrument:place:east-wing"
        ],
        [
          "t",
          "cartographers-instrument"
        ],
