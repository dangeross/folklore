{
  "walkthrough": [
    "# Tide's End 03: State & Logic — Walkthrough",
    "# This world teaches State, Transitions, Requires, and Counters.",
    "# Start at The Dock.",
    "",
    "> look",
    "# You see The Dock. A lantern sits on the planks. Exits: north, east.",
    "",
    "> get lantern",
    "# You pick up the lantern. It is unlit.",
    "",
    "> north",
    "# Arrive at Village Square. A stone well stands in the centre. Exits: south, east, west.",
    "",
    "> east",
    "# Arrive at The Tavern. A matchbox sits on the bar. Exits: west, down.",
    "",
    "> get matchbox",
    "# You pick up the matchbox.",
    "",
    "> light lantern",
    "# 'You strike the flint. The lantern flares to life.'",
    "",
    "> down",
    "# The portal requires the lantern in state 'lit'. You have it. Arrive at The Cellar.",
    "",
    "> get map",
    "# You pick up the old map.",
    "",
    "> up",
    "# Back at The Tavern.",
    "",
    "> west",
    "# Back at Village Square.",
    "",
    "> crank well",
    "# Counter 'cranks' increments to 1.",
    "",
    "> crank well",
    "# Counter 'cranks' increments to 2.",
    "",
    "> crank well",
    "# Counter 'cranks' increments to 3. on-counter fires: set-state 'raised'.",
    "# Transition text: 'The bucket rises from the depths, water sloshing.'",
    "",
    "> get rope",
    "# The wet rope requires well in state 'raised'. Condition met. You pick up the rope.",
    "",
    "# All items collected. Walkthrough complete."
  ],
