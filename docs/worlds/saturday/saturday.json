    {
      "kind": 30078,
      "tags": [
        ["d", "saturday:feature:chore-list"],
        ["t", "saturday"],
        ["type", "feature"],
        ["title", "Chore List"],
        ["state", "posted"],
        ["noun", "chore list", "list", "note", "chores", "envelope"]
      ],
      "content": "Mum's handwriting on a torn envelope:\n\nWashing up — 2 coins\nTidying your room — 2 coins\nMowing the lawn — 3 coins\n\nToy shop is south. Back by four."
    },

    {
      "kind": 30078,
      "tags": [
        ["d", "saturday:feature:sofa"],
        ["t", "saturday"],
        ["type", "feature"],
        ["title", "The Sofa"],
        ["state", "unsearched"],
        ["noun", "sofa", "couch", "cushions"],
        ["verb", "search", "look down", "check"],
        ["on-interact", "search", "unsearched", "add-counter", "coins", "1"],
        ["on-interact", "search", "unsearched", "set-state", "searched"],
        ["on-interact", "search", "searched", "set-state", "searched"],
        ["transition", "unsearched", "searched", "Down the back of the cushions: a coin, a pen lid, and something that might once have been a grape. (+1 coin)"],
        ["transition", "searched", "searched", "Just the pen lid now."]
      ],
      "content": "A three-seater in a colour that used to have a name. Well sat-in. Things have a way of falling down the back."
    },

    {
      "kind": 30078,
      "tags": [
        ["d", "saturday:npc:dad"],
        ["t", "saturday"],
        ["type", "npc"],
        ["title", "Dad"],
        ["noun", "dad", "father"],
        ["dialogue", "30078:<PUBKEY>:saturday:dialogue:dad-coin"],
        ["dialogue", "30078:<PUBKEY>:saturday:dialogue:dad-after", "30078:<PUBKEY>:saturday:npc:dad", "chatted"]
      ],
      "content": "Dad at the kitchen table with the racing pages and a mug that has gone cold. He doesn't know this yet."
    },

    {
      "kind": 30078,
      "tags": [
        ["d", "saturday:dialogue:dad-coin"],
        ["t", "saturday"],
        ["type", "dialogue"],
        ["on-enter", "player", "", "add-counter", "coins", "1"],
        ["on-enter", "player", "", "set-state", "chatted", "30078:<PUBKEY>:saturday:npc:dad"]
      ],
      "content": "He reaches into his pocket without looking up from the racing pages. Here, he says. Don't tell your mother. (+1 coin)"
    },

    {
      "kind": 30078,
      "tags": [
        ["d", "saturday:dialogue:dad-after"],
        ["t", "saturday"],
        ["type", "dialogue"]
      ],
      "content": "He's back to the racing pages."
    },

