        ["type", "world"],
        ["title", "Saturday"],
        ["start", "30078:<PUBKEY>:saturday:place:home"],
        ["collaboration", "closed"],
        ["counter", "coins", "0"],
        ["hud", "Coins: {{coins}}"]
      ],
      "content": "A Saturday morning. There are things to do — and things to spend money on."
    },

    {
      "kind": 30078,
      "tags": [
        ["d", "saturday:place:home"],
        ["t", "saturday"],
        ["type", "place"],
        ["title", "Front Room"],
        ["npc", "30078:<PUBKEY>:saturday:npc:mum"],
        ["feature", "30078:<PUBKEY>:saturday:feature:chore-list"],
        ["feature", "30078:<PUBKEY>:saturday:feature:sofa"],
        ["exit", "north"],
        ["exit", "east"],
        ["exit", "upstairs"],
        ["exit", "south"]
      ],
      "content": "Mum is in her usual chair with a mug of tea. She looks like she has been up since before the birds. There is a sofa against the wall — worth searching.\n\nKitchen is north. Back garden east. Upstairs to your bedroom. South is the street — the toy shop is down there."
    },

    {
      "kind": 30078,
      "tags": [
        ["d", "saturday:place:kitchen"],
        ["t", "saturday"],
        ["type", "place"],
        ["title", "The Kitchen"],
        ["feature", "30078:<PUBKEY>:saturday:feature:sink"],
        ["npc", "30078:<PUBKEY>:saturday:npc:dad"],
        ["exit", "south"]
      ],
      "content": "A narrow kitchen. The sink is piled with last night's dishes. Dad is at the table with the racing pages and a mug that has gone cold.\n\nFront room is south."
    },

    {
      "kind": 30078,
      "tags": [
        ["d", "saturday:place:garden"],
        ["t", "saturday"],
        ["type", "place"],
        ["title", "The Back Garden"],
        ["feature", "30078:<PUBKEY>:saturday:feature:lawn"],
        ["exit", "west"]
      ],
      "content": "A rectangular strip of grass. Overdue a cut. The mower is in the shed beside it. One of its wheels wobbles.\n\nFront room is west."
    },

    {
      "kind": 30078,
      "tags": [
        ["d", "saturday:place:bedroom"],
        ["t", "saturday"],
        ["type", "place"],
        ["title", "Your Bedroom"],
        ["feature", "30078:<PUBKEY>:saturday:feature:floor"],
        ["exit", "downstairs"]
      ],
      "content": "You know which piles are which. Mum does not see it that way.\n\nDownstairs is the front room."
    },

    {
      "kind": 30078,
      "tags": [
        ["d", "saturday:place:cornershop"],
        ["t", "saturday"],
        ["type", "place"],
        ["title", "The Corner Shop"],
        ["feature", "30078:<PUBKEY>:saturday:feature:sweets-stand"],
        ["exit", "north"],
        ["exit", "south"]
      ],
      "content": "A narrow shop with a bell above the door. Newspapers, bread, tins of things. A rotating stand of sweets near the counter. There is a handwritten sign: No Ball Games. You are not playing ball games.\n\nHome is north. Patel's Toys is south."
    },

    {
      "kind": 30078,
      "tags": [
        ["d", "saturday:place:toyshop"],
        ["t", "saturday"],
        ["type", "place"],
        ["title", "Patel's Toys"],
        ["npc", "30078:<PUBKEY>:saturday:npc:shopkeeper"],
        ["feature", "30078:<PUBKEY>:saturday:feature:yoyo-shelf"],
        ["feature", "30078:<PUBKEY>:saturday:feature:figure-shelf"],
        ["feature", "30078:<PUBKEY>:saturday:feature:car-shelf"],
        ["exit", "north"]
      ],
      "content": "A small shop that smells of cardboard and ambition. Hand-written price tags. Behind the counter stands Mr Patel.\n\nNorth is home."
    },

